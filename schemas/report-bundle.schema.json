{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportBundle",
  "type": "object",
  "required": [
    "report",
    "methods",
    "commands",
    "environment",
    "checksums",
    "provenance",
    "preregistration",
    "run_manifest"
  ],
  "properties": {
    "report": { "type": "string" },
    "methods": { "type": "string" },
    "commands": { "type": "string" },
    "environment": { "type": "string" },
    "checksums": { "type": "string" },
    "events": {
      "type": "object",
      "properties": {
        "sidecar": { "type": "string" },
        "tables": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "model": {
      "type": "object",
      "properties": {
        "input": { "type": "string" },
        "manifest": { "type": "string" },
        "bayesian_condition_effects": { "type": "string" },
        "bayesian_diagnostics": { "type": "string" },
        "ddm_status": { "type": "string" }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "psychds": { "type": ["string", "null"] },
        "bids": { "type": ["string", "null"] },
        "hed": { "type": ["string", "null"] }
      }
    },
    "bids_intake": {
      "type": "object",
      "required": [
        "root",
        "dataset_description",
        "readme",
        "participants_tsv",
        "participants_json",
        "intake_manifest",
        "placeholder_files",
        "validator_artifact"
      ],
      "properties": {
        "root": { "type": "string" },
        "dataset_description": { "type": "string" },
        "readme": { "type": "string" },
        "participants_tsv": { "type": "string" },
        "participants_json": { "type": "string" },
        "intake_manifest": { "type": "string" },
        "placeholder_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validator_artifact": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["ro_crate", "prov"],
      "properties": {
        "ro_crate": { "type": "string" },
        "prov": { "type": "string" }
      }
    },
    "preregistration": {
      "type": "object",
      "required": ["artifact"],
      "properties": {
        "artifact": { "type": "string" }
      }
    },
    "run_manifest": { "type": "string" }
  }
}
